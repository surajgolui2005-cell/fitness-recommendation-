{
  "name": "fitness-app-backend",
  "version": "1.0.0",
  "description": "Fitness App Backend",
  "main": "server.js",
  "scripts": {
    "start":    "node server.js",
    "dev":      "concurrently --names \"NODE,ML\" --prefix-colors \"cyan,magenta\" \"nodemon server.js\" \"python ml/app.py\"",
    "dev:node": "nodemon server.js",
    "dev:ml":   "python ml/app.py"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb-memory-server": "^11.0.1",
    "mongoose": "^8.3.2",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
